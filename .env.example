# -- 🔌 LLM connection -------------------------------------------------
# Talos speaks to any OpenAI-compatible endpoint. Point it at your
# provider with a base URL + API key + model name.
#
#   OpenAI      -> leave TALOS_BASE_URL unset, model e.g. gpt-4o-mini
#   Anthropic   -> TALOS_BASE_URL=https://api.anthropic.com/v1/   model e.g. claude-sonnet-4-5
#   OpenRouter  -> TALOS_BASE_URL=https://openrouter.ai/api/v1    model e.g. anthropic/claude-sonnet-4.5
#   Ollama      -> TALOS_BASE_URL=http://localhost:11434/v1       model e.g. llama3.1 (key can be anything)

TALOS_BASE_URL=
TALOS_API_KEY=sk-...
TALOS_MODEL=gpt-4o-mini

# Sampling temperature (0 = deterministic-ish, good for agents)
# TALOS_TEMPERATURE=0.0

# 🧭 Embedding model → vector recall in graph memory (cosine similarity
# instead of keywords). Unset = keyword recall.
#   in-process (recommended; pip install fastembed, no endpoint needed):
#     TALOS_EMBED_MODEL=local:all-MiniLM-L6-v2
#   via the chat endpoint's /embeddings API:
#     OpenAI -> text-embedding-3-small   Ollama -> nomic-embed-text
# TALOS_EMBED_MODEL=

# Max agent-loop super-steps before aborting (one think->act round = 2)
# TALOS_MAX_ITERATIONS=50

# 🔓 TLS verification for LLM + web traffic. Only set false behind a
# corporate proxy that re-signs traffic (prefer SSL_CERT_FILE=<proxy CA>).
# TALOS_VERIFY_SSL=true

# 📦 Shell sandbox: off | docker (docker runs each shell command in a
# throwaway, network-isolated container; zero overhead when off)
# TALOS_SANDBOX=off

# 💭 Think mode: reason in a <thinking> scratchpad before answering
# (works on any model; /think toggles it live)
# TALOS_THINK=false
